class Car:
    def __init__(self, model, year, color, for_sale):
        self.model = model
        self.year = year
        self.color = color
        self.for_sale = for_sale

    def drive(self):
        print(f"Driving the {self.model}")

    def stop(self):
        print(f"Stopping the {self.model}")

    def __str__(self):
        return f"{self.year} {self.color} {self.model} (For sale: {self.for_sale})"


# Creating objects
car1 = Car("Audi", 2024, "red", True)
car2 = Car("Mustang", 2024, "black", True)
car3 = Car("BMW", 2025, "wine", False)


# Accessing attributes
print(car2.model)
print(car1.year)
print(car3.color)
print(car1.for_sale)

print()  # empty line

# Using methods
car1.drive()
car2.stop()

print()  # empty line

# Printing full object info
print(car1)
print(car2)
print(car3)
